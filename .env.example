# Ключ Яндекс.Карт (JavaScript API и HTTP Геокодер).
# Получить: https://developer.tech.yandex.ru/services/
VITE_YANDEX_MAPS_API_KEY=

# Базовый путь к API отслеживания.
# В dev по умолчанию используется Vite-прокси (/trcont-api), обходящий CORS.
# В проде укажите адрес своего бэкенд-прокси.
VITE_API_BASE=/trcont-api

# Номер отслеживаемого контейнера (захардкожен под одну машину).
VITE_CONTAINER_NUMBER=TKRU4596490

# URL серверной истории, собираемой GitHub Actions (ветка data).
# Репозиторий должен быть публичным, чтобы raw.githubusercontent отдавал файл.
VITE_HISTORY_URL=https://raw.githubusercontent.com/ilyaip/audi-tracker/data/history.json
